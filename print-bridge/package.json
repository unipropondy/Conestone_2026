{
  "name": "unipro-print-bridge",
  "version": "1.0.0",
  "description": "Standalone LAN/Wi-Fi Print Bridge for POS Web to Kitchen Printers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "package": "npm run build && pkg . --targets node18-win-x64 --output dist/UniProPrintBridge.exe"
  },
  "bin": "dist/index.js",
  "pkg": {
    "assets": [
      "config.json"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
